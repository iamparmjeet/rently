{
  "name": "be",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "rm -rf dist && tsc",
    "lint": "biome lint .",
    "lint:check": "biome check .",
    "lint:fix": "biome format --write",
    "typecheck": "tsc --noEmit",
    "generate:betterauth": "bunx @better-auth/cli generate --config /src/lib/auth.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "build:types": "tsc -b",
    "db:up": "docker compose -f docker-compose.yaml -f docker-compose.local.yaml up -d",
    "db:down": "docker compose -f docker-compose.yaml -f docker-compose.local.yaml down",
    "db:logs": "docker compose -f docker-compose.yaml -f docker-compose.local.yaml logs -f db"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^12.0.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.15",
    "hono-pino": "^0.10.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^24.12.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
