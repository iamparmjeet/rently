{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "jsxImportSource": "hono/jsx",
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "lib": ["ESNext"],
    "jsx": "react-jsx",
  },
  "include": ["src/**/*"]
}
