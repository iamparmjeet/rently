{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "react",
    "unicorn",
    "oxc"
  ],
  "extends": [
    "recommended"
  ],
  "rules": {
    "react/no-unknown-property": "error"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  }
}
