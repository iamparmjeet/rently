{
  "lsp": {
    "biome": {
      "binary": {
        "arguments": [
          "lsp-proxy"
        ]
      }
    }
  },
  "formatter": "language_server",
  "format_on_save": "on",
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": [
            "check",
            "--write",
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": [
            "check",
            "--write",
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "biome",
          "arguments": [
            "check",
            "--write",
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
    },
  },
  "code_actions_on_format": {
    "source.organizeImports.biome": true,
    "source.fixAll.biome": true,
  },
}
