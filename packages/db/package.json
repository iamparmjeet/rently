{
	"name": "@rently/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"db:start": "docker compose up -d",
		"db:watch": "docker compose up",
		"db:stop": "docker compose stop",
		"db:up": "docker compose -f docker-compose.yaml up -d",
		"db:down": "docker compose -f docker-compose.yaml down"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0",
		"@rently/env": "workspace:*",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"pg": "^8.20.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@rently/config": "workspace:*",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^6.0.3"
	}
}
