{
  "formatter": "language_server",
  "format_on_save": "on",
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": [
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": [
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": [
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
    },
  },
  "code_actions_on_format": {
    "source.organizeImports": true,
    "source.fixAll": true,
  },
}
